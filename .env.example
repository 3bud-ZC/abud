############################################################
# DATABASE  (Neon / PostgreSQL)
# ----------------------------------------------------------
# في الإنتاج (Vercel) وفي التطوير المحلي:
#   استخدم URL من Neon.tech (مجاني). يجب أن يحتوي على
#   ?sslmode=require في النهاية.
#
# مثال:
#   DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/abud?sslmode=require"
############################################################
DATABASE_URL=""

############################################################
# SESSION SECRET
# ----------------------------------------------------------
# مفتاح التوقيع للجلسات. يجب أن يكون عشوائياً وطويلاً.
# توليده محلياً:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
############################################################
SESSION_SECRET=""

############################################################
# الرابط الأساسي للموقع (يستخدم في SEO و sitemap و OpenGraph)
#   تطوير محلي:  http://localhost:3000
#   إنتاج:        https://yourdomain.com
############################################################
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

############################################################
# بيانات الأدمن الافتراضية (تُستخدم عند تشغيل seed أول مرة)
# غيّرها قبل النشر للإنتاج.
############################################################
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="ChangeMe@StrongPassword123"

############################################################
# مجلد رفع الملفات (إثباتات الدفع وغيرها)
# ملاحظة: على Vercel الـ filesystem read-only، لذا للإنتاج
# يفضل استخدام Cloudinary / S3 / UploadThing.
############################################################
UPLOAD_DIR="./public/uploads"

############################################################
# AI (اختياري — لتفعيل ميزات المساعد الذكي)
# AI_MODEL_PROVIDER:  "openai" | "anthropic" | "google"
############################################################
AI_MODEL_API_KEY=""
AI_MODEL_PROVIDER="openai"

############################################################
# Google Analytics 4 (اختياري)
# Measurement ID يبدأ بـ G-
############################################################
NEXT_PUBLIC_GA_ID=""

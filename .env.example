############################################################
# إعدادات قاعدة البيانات (Prisma / SQLite)
# في التطوير نستخدم ملف SQLite محلي.
############################################################
DATABASE_URL="file:./dev.db"

############################################################
# مفتاح سري للجلسات (JWT / Cookies)
# مهم جداً للأمان في الإنتاج:
# - غيّره لقيمة عشوائية قوية (على الأقل 32 حرف)
# - لا تشاركه ولا ترفعه على Git
############################################################
SESSION_SECRET="change-this-to-a-very-long-random-secret-minimum-32-characters"

############################################################
# رابط الموقع الأساسي
# يستخدم في:
# - SEO (meta / OpenGraph)
# - sitemap
# في البيئة المحلية: http://localhost:3000
# في الإنتاج: غيّره إلى الدومين الحقيقي (مثال: https://abud.fun)
############################################################
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

############################################################
# بيانات تسجيل الدخول الافتراضية للوحة التحكم (Admin)
# يفضل تغييرها بعد أول تسجيل دخول في الإنتاج.
############################################################
ADMIN_EMAIL="admin@abud.com"
ADMIN_PASSWORD="Admin@1234"

############################################################
# مجلد رفع الملفات (صور إثبات الدفع / ملفات أخرى)
# المسار الافتراضي داخل مجلد public
############################################################
UPLOAD_DIR="./public/uploads"

############################################################
# إعدادات بايبال (اختياري)
# إذا لم تستخدم بايبال يمكنك تركها فارغة.
############################################################
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"

############################################################
# إعدادات الذكاء الاصطناعي (AI)
# لتفعيل ميزات AI في المنصة:
# 1) ضع مفتاح الـ API في AI_MODEL_API_KEY
# 2) اختر المزود في AI_MODEL_PROVIDER:
#    - "openai"    للـ OpenAI
#    - "anthropic" لـ Claude (Anthropic)
#    - "google"    لـ Gemini
# إذا تُركت هذه القيم فارغة، ستظهر رسالة توضح أن خدمة AI غير مفعّلة.
############################################################
AI_MODEL_API_KEY=""
AI_MODEL_PROVIDER="openai"

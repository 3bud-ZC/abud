# Production Environment Variables for ABUD Platform
# Copy this file to .env on your VPS and update the values

# Database Configuration
DATABASE_URL="postgresql://abud_user:YOUR_SECURE_PASSWORD@localhost:5432/abud_platform"

# Session Secret (Generate with: openssl rand -base64 32)
SESSION_SECRET="REPLACE_WITH_RANDOM_32_CHAR_STRING"

# Application Environment
NODE_ENV=production
PORT=3000

# Site URL
NEXT_PUBLIC_SITE_URL="https://abud.fun"

# Upload Directory
UPLOAD_DIR="public/uploads"

# Server Information
SERVER_IP=72.62.39.204
SERVER_USER=abdullah
PROJECT_PATH=/home/abdullah/abud

# Optional: Email Configuration (if needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: Payment Gateway Keys (if needed)
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_SECRET=your_paypal_secret

# Optional: Analytics (if needed)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
